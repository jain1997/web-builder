OPENAI_API_KEY=sk-your-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.1
LLM_MODEL_SMALL=gpt-5-mini-2025-08-07
CORS_ORIGINS=http://localhost:3000

# Ollama image generation (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_IMAGE_MODEL=x/flux2-klein:latest

# Redis (active session cache)
REDIS_URL=redis://localhost:6379/0
SESSION_CACHE_TTL=3600

# SQLite (conversation history + file snapshots)
DATABASE_PATH=data/agentic.db

# Image storage
IMAGE_STORAGE_PATH=data/images
PUBLIC_URL=http://localhost:8000

# Auth (optional — leave empty for no auth)
WS_AUTH_KEY=

# Logging (dev = colored text, json = structured JSON for production)
LOG_FORMAT=dev
